# Run at Openbox session start.

# TV UI scaling (must run before apps launch)
xrdb -merge ~/.Xresources

# Compositor: fixes black/white artifacts behind menu rounded corners
# and shadows, enables transparency; vsync prevents video tearing
picom --backend glx --vsync -b

# Notification daemon (used for the volume popup)
dunst &

# Media center UI: restart whenever it exits, as long as the X session
# is still alive (the xprop check stops the loop after logout)
(cd /media; while xprop -root >/dev/null 2>&1; do
  ~/ghq/github.com/JanPokorny/tiny-media-center/target/release/tiny-media-center
  sleep 1
done) &
